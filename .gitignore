# Ignore all sibling folders and files in the parent directory
/*

# Except the agapp-system folder (and this gitignore itself)
!/agapp-system/
!/.gitignore

# Allow Manuscript folder for editing/review
!/Manuscript/
# !/Wireframes/
# !/AGAPP-ClEANED/

# Allow the docs vault and project guide to be tracked
!/Docs/
!/CLAUDE.md
!/AGAPP - ASSETS

# Ignore Obsidian workspace files (which contain local layout, tabs, and history state)
/Docs/.obsidian/workspace.json
/Docs/.obsidian/workspace-mobile.json

