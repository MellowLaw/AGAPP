{
  "name": "agapp-monorepo",
  "version": "1.0.0",
  "description": "AGAPP - Automated Governance and Public Service Platform",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "nohoist": [
      "**/expo",
      "**/expo/**",
      "**/react-native",
      "**/react-native/**",
      "**/react",
      "**/react/**",
      "**/@expo/**",
      "**/@react-native/**",
      "**/@react-native-community/**"
    ]
  },
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=apps/admin\"",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:admin": "npm run dev --workspace=apps/admin",
    "dev:mobile": "cd apps/mobile && npx expo start",
    "install:all": "npm install",
    "build:all": "npm run build --workspaces --if-present",
    "build:shared": "npm run build --workspace=packages/shared"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1"
  },
  "overrides": {
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.16.0",
    "@react-native-async-storage/async-storage": "2.2.0"
  }
}
