# ============================================================
#  AGAPP Expo Mobile — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the actual .env file.
#  Note: In Expo, env vars must be prefixed with EXPO_PUBLIC_
#        to be accessible in client-side JS bundles.
# ============================================================

# NestJS API base URL
# For Expo Go on your phone: replace with your machine's local IP
# e.g. http://192.168.1.x:5000/api
EXPO_PUBLIC_API_URL=http://localhost:5000/api

# Supabase (if you later switch mobile to use Supabase directly)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
