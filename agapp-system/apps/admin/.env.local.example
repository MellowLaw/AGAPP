# ============================================================
#  AGAPP Next.js Admin — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit the actual .env.local file.
# ============================================================

# Supabase Project (Settings → API in your Supabase Dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# NestJS API base URL (used for server-to-server calls if needed)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Demo Quick Login passwords (seeded accounts only). No NEXT_PUBLIC_ prefix —
# read server-side only, by /api/demo-login. Only fill these in your local
# .env.local — never commit real values here.
#
# Store as base64, not plaintext: Next.js's built-in env loader (@next/env)
# expands $VAR-style references inside .env values (unlike plain dotenv), so
# a password containing "$" gets silently truncated at load time. Base64
# sidesteps that — it's just an encoding (not a secret-protection measure),
# purely to survive Next.js's env parser intact.
#   node -e "console.log(Buffer.from('yourPassword','utf8').toString('base64'))"
DEMO_SUPERADMIN_PASSWORD_B64=
DEMO_LGUADMIN_PASSWORD_B64=
DEMO_PERSONNEL_PASSWORD_B64=
