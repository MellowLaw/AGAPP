# ============================================================
#  AGAPP NestJS API — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the actual .env file.
# ============================================================

# Supabase Project (Settings → API in your Supabase Dashboard)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-secret-key

# Mistral AI (https://admin.mistral.ai/organization/api-keys — La Plateforme,
# NOT the Le Chat subscription, which is a separate product with no API access).
# Used by the citizen chatbot fallback (mistral-small-latest).
MISTRAL_API_KEY=your-mistral-api-key

# Google Gemini (https://aistudio.google.com/apikey)
# Used by forum post/comment AI moderation only. Optional — falls back to the
# local keyword/PII filter if unset or if the call fails.
GEMINI_API_KEY=your-gemini-api-key

# Server
PORT=5000
