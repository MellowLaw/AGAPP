# ============================================================
#  AGAPP NestJS API — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the actual .env file.
# ============================================================

# Supabase Project (Settings → API in your Supabase Dashboard)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-secret-key

# Mistral AI (https://admin.mistral.ai/organization/api-keys — La Plateforme,
# NOT the Le Chat subscription, which is a separate product with no API access).
# Used by the citizen chatbot fallback (mistral-small-latest).
MISTRAL_API_KEY=your-mistral-api-key

# (GEMINI_API_KEY removed 2026-07-05 — the API forum-moderation endpoints that
# used it were dead code nothing called; the real moderation is the DB trigger
# check_forum_profanity() + admin manual review.)

# Roboflow (get the key from the SPECIFIC workspace's Settings → Roboflow API →
# Private API Key while you're inside that workspace — keys are per-workspace,
# not account-wide; the Publishable key won't work here, it's read-only).
# Used by POST /api/reports/verify-image (2026-07-06). Two deployed models, both
# on serverless.roboflow.com, format https://serverless.roboflow.com/<slug>/<version>:
#   - POTHOLE:   a fine-tuned single-class model (agapp-y5jbd) — any detection = valid.
#   - STRAYPETS: a stock COCO YOLOv8n (agapp-stray-pets) — the API keeps only
#                dog/cat predictions to validate the photo.
# Without a given model's URL set (or the key), that category returns nulls
# ("not analyzed") — verify-image never fabricates a confidence value.
ROBOFLOW_API_KEY=your-roboflow-private-api-key
ROBOFLOW_POTHOLE_MODEL_URL=https://serverless.roboflow.com/your-pothole-slug/1
ROBOFLOW_STRAYPETS_MODEL_URL=https://serverless.roboflow.com/your-straypets-slug/1

# Server
PORT=5000

# CORS allowlist: comma-separated list of origins allowed to call this API from
# a browser (e.g. the admin dashboard's deployed URL). The mobile app is React
# Native, not a browser, so it's unaffected by CORS and doesn't need an entry.
# If unset, CORS falls back to wide-open (all origins) with a console warning —
# fine for local dev, NOT for production.
# ALLOWED_ORIGINS=https://admin.agapp.example.com,http://localhost:3000
