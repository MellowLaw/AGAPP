# ============================================================
#  AGAPP Field Officer (Expo) — Environment Variables
#  Copy to .env and fill in real values. Without this file the
#  Supabase client is created with an empty URL and every
#  request (login, QR pickup scanning) silently fails.
# ============================================================

# Supabase project (same project as mobile/admin)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# LAN IP of the dev machine, so a phone on the same Wi-Fi can reach Metro
REACT_NATIVE_PACKAGER_HOSTNAME=192.168.x.x
